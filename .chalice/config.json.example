{
  "version": "2.0",
  "app_name": "card-prices",
  "automatic_layer": true,
  "stages": {
    "dev": {
      "api_gateway_stage": "api",
      "autogen_policy": false,
      "iam_policy_file": "policy-dev.json",
      "lambda_memory_size": 512,
      "lambda_timeout": 60,
      "layers": [
        "arn:aws:lambda:<region>:<account-id>:layer:card-prices-matplotlib:<version>"
      ],
      "environment_variables": {
        "POKEMONTCG_API_KEY": "<your-pokemontcg-io-api-key>",
        "PRICES_TABLE": "CardPrices",
        "WATCHLIST_TABLE": "CardWatchlist",
        "PLOT_BUCKET": "<your-plot-bucket>",
        "PLOT_PREFIX": "plots",
        "USE_PUBLIC_ACL": "false",
        "LOG_LEVEL": "INFO"
      }
    }
  }
}
